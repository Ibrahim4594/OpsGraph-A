# Never bake host-only state into the image.
.venv/
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Secrets — defence in depth; these should never be in the working tree
# but we exclude them anyway so a stray copy doesn't ship.
.env
.env.*
!.env.example

# Editor noise.
.vscode/
.idea/
*.swp
